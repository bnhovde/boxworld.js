{
  "compilerOptions": {
    "target": "es2019",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["es2019", "dom", "dom.iterable"],
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": false,
    "sourceMap": true,
    "outDir": "./dist/"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "example"]
}
