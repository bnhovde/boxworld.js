{
  "name": "boxworld",
  "version": "1.0.0",
  "description": "Really basic DOM-based game engine for 2.5D games",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./boxworld.css": "./dist/boxworld.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "node scripts/example.mjs",
    "example": "node scripts/example.mjs",
    "build": "tsup",
    "build:example": "node scripts/example.mjs --build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "game-engine",
    "2.5d",
    "isometric",
    "dom",
    "css",
    "html5-game"
  ],
  "author": "Bård N. Hovde",
  "license": "ISC",
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "directories": {
    "example": "example"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bnhovde/boxworld.js.git"
  },
  "bugs": {
    "url": "https://github.com/bnhovde/boxworld.js/issues"
  },
  "homepage": "https://github.com/bnhovde/boxworld.js#readme"
}
